# KAMISUMI / KAGURAKOJI Commerce Core - environment template
# 実際の値は .env.local に置く（.env / .env*.local は .gitignore 済み）。
# 秘密鍵・実口座番号・顧客情報・本番APIキーはコミットしないこと。

# ---- データバックエンド切替 ----
# mock（既定） or supabase。未設定なら mock で動作（Phase 1 と同じ）。
DATA_BACKEND=mock

# ---- Supabase（Phase 2A）----
# 公開可（ブラウザに露出してよい）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー専用（絶対にクライアントへ出さない・コミットしない）
SUPABASE_SERVICE_ROLE_KEY=
# DB マイグレーション用（supabase CLI / psql）
SUPABASE_DB_URL=

# ---- 管理画面（Phase 2A）----
# 管理画面の有効化。既定（未設定/true以外）では /admin は真の404。
ADMIN_ENABLED=
# 開発用 mock 認証ロール（owner|front_staff|inventory_staff|editor）。
# Supabase Auth 導入後は不要（getAdminSession が session+user_roles を使う）。
ADMIN_DEV_ROLE=
# 管理画面の認証モード（mock|supabase）。未設定なら DATA_BACKEND に追従
# （supabase バックエンド時のみ Supabase Auth、それ以外は mock）。
ADMIN_AUTH_MODE=

# ---- サイト ----
# 既定は src/config/site.ts の siteUrl。プレビュー等で上書きしたい場合のみ設定。
NEXT_PUBLIC_SITE_URL=

# ---- 取り置き/買付（Phase 2A 既定値。実値は管理画面/設定で調整）----
HOLD_DEFAULT_HOURS=48

# ---- 外部連携 interface（Phase 3 以降・本番送信/決済はしない）----
# メール送信サービス（本番契約後に設定）
EMAIL_PROVIDER=
EMAIL_FROM=
# 決済（sandbox/mock のみ。本番キーは入れない）
STRIPE_SECRET_KEY=
SHOPIFY_STOREFRONT_TOKEN=
