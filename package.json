{
  "name": "kamisumi-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "db:validate": "node scripts/validate-migrations.mjs",
    "dev:mock": "cross-env ADMIN_ENABLED=true ADMIN_DEV_ROLE=owner next dev",
    "dev:owner": "cross-env ADMIN_ENABLED=true ADMIN_DEV_ROLE=owner next dev",
    "dev:front": "cross-env ADMIN_ENABLED=true ADMIN_DEV_ROLE=front_staff next dev",
    "dev:inventory": "cross-env ADMIN_ENABLED=true ADMIN_DEV_ROLE=inventory_staff next dev",
    "dev:public": "cross-env ADMIN_ENABLED=false next dev",
    "mock:reset": "node scripts/mock-reset.mjs",
    "stop": "node scripts/stop.mjs",
    "verify:public": "node scripts/smoke.mjs public",
    "verify:admin": "node scripts/smoke.mjs admin",
    "verify:mock": "node scripts/smoke.mjs mock",
    "verify:quick": "node scripts/smoke.mjs quick",
    "verify:full": "npm run typecheck && npm run lint && npm run test && npm run db:validate && npm run build"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@playwright/test": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^10.1.0",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "jsdom": "latest",
    "prettier": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
